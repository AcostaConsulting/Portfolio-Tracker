{
  "name": "portfolio-tracker",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "description": "Tracker de Portafolio Personal — app local para llevar inversiones en una sola moneda base.",
  "author": "Tracker de Portafolio",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "icon": "node scripts/make-icon.cjs",
    "app:smoke": "electron .",
    "app:build": "npm audit --audit-level=high --omit=dev && npm run build && npm run icon && electron-builder --win && node scripts/checksums.cjs",
    "app:publish": "npm audit --audit-level=high --omit=dev && npm run build && npm run icon && electron-builder --win --publish always && node scripts/checksums.cjs"
  },
  "dependencies": {
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "i18next": "^26.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "recharts": "^2.13.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
